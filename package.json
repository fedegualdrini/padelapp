{
  "name": "webtemp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run",
    "test:db": "node scripts/test-db-reset.mjs",
    "test:e2e": "playwright test",
    "test:e2e:full": "./scripts/run-e2e-tests.sh",
    "test": "npx run-s typecheck lint test:unit test:db test:e2e",
    "test:verify": "./scripts/verify-test-db.sh",
    "test:with-timeout": "./scripts/test-with-timeout.sh",
    "gateway:check": "./scripts/check-gateway-health.sh",
    "gateway:retry": "./scripts/retry-cron-op.sh",
    "cron:update": "./scripts/safe-cron-update.sh",
    "bundle:analyze": "ANALYZE=true npm run build",
    "bundle:size": "du -sh .next/static/chunks/*.js | awk '{sum+=$1} END {print \"Total JS: \" sum \"MB\"}'"
  },
  "bundleSizeLimits": {
    "maxChunkSize": "300KB",
    "maxTotalJS": "2MB",
    "maxCSS": "150KB"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.95.3",
    "date-fns": "^4.1.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "sonner": "^2.0.7",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "10.2.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.0.2",
    "npm-run-all": "^4.1.5",
    "pg": "^8.20.0",
    "supabase": "^2.89.1",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.4"
  }
}
